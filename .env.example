# Django
SECRET_KEY=your-secret-key-here-generate-with-django-get-random-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Email (SMTP — leave empty to use console backend in development)
DEFAULT_FROM_EMAIL=noreply@wholecakegroup.co.za
EMAIL_HOST=smtp.yourmailprovider.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-smtp-username
EMAIL_HOST_PASSWORD=your-smtp-password
NOTIFICATION_EMAIL=info@wholecakegroup.co.za

# Site contact details (displayed in footer/contact page)
CONTACT_EMAIL=info@wholecakegroup.co.za
CONTACT_PHONE=+27 ...

# Analytics (leave empty to disable)
GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
